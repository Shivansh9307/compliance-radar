table company_risk
	lineageTag: 4c91f353-173a-401b-aaff-54391c7ae8df

	measure 'Total Companies' = COUNTROWS(company_risk)
		formatString: 0
		lineageTag: 8b4a12c3-34eb-43d2-b3c7-9ad52ff0126c

	measure 'High Risk' = CALCULATE(COUNTROWS(company_risk), company_risk[risk_tier] = "High")
		formatString: 0
		lineageTag: f8f240a3-38f7-4cc8-98be-976a5c5c981f

	measure 'Medium Risk' = CALCULATE(COUNTROWS(company_risk), company_risk[risk_tier] = "Medium")
		formatString: 0
		lineageTag: d0bd0dd5-6208-4ac9-85ef-c13a63c894df

	measure '% High Risk' = DIVIDE([High Risk], [Total Companies])
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 40c25401-3a3c-4881-ac90-f4eb82af3cd2

	measure 'AI-Flagged Companies' =
			CALCULATE(
			    COUNTROWS(company_risk),
			    FILTER(company_risk,
			        company_risk[flag_going_concern] = 1
			     || company_risk[flag_auditor_resignation] = 1
			     || company_risk[flag_related_party] = 1))
		formatString: 0
		lineageTag: 3d9083f7-6bf2-4742-bc65-4e048f7f0de0

